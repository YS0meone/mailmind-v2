# Nylas (Hosted Auth — handles Google OAuth internally)
NYLAS_CLIENT_ID=your_nylas_client_id
NYLAS_API_KEY=your_nylas_api_key
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_WEBHOOK_SECRET=your_nylas_webhook_secret

# Session
SESSION_SECRET=generate-a-random-secret-here

# OpenAI (for embeddings + LLM)
OPENAI_API_KEY=your_openai_api_key

# --- Optional overrides (defaults work out of the box) ---
# DATABASE_URL=postgresql+asyncpg://mailmind:mailmind_dev@localhost:5432/mailmind
# BACKEND_CORS_ORIGINS=http://localhost:3000
